<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ConvertX" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>

    <style name="Theme.ConvertX.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0B0512</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.ConvertX</item>
    </style>
</resources>
