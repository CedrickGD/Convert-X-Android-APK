# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios

# Android prebuild output IS tracked (we have Phase 8 customizations in
# android/app/build.gradle + proguard-rules.pro that must survive
# `expo prebuild`). Only ignore the build outputs / per-machine config:
/android/.gradle/
/android/.cxx/
/android/.kotlin/
/android/build/
/android/app/.cxx/
/android/app/build/
/android/local.properties
/android/captures/

# Local Expo module build outputs
modules/*/android/build/
modules/*/android/.gradle/
modules/*/android/.cxx/

# IDE
.idea/

# Local screenshots / APK builds used for visual verification during dev
.claude/*.png
.claude/*.xml
.claude/*.apk

# Release pipeline outputs (built APKs)
release/

# Local gradle properties — release signing config (see android/gradle.properties.example)
android/gradle.properties.local
